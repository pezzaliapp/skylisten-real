{
  "name": "skylisten-real",
  "version": "1.1.0",
  "description": "Prototipo civile e gratuito di rete acustica per il rilevamento passivo di droni.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"*.{js,css,html,json,md}\" \"js/**/*.js\" \"server/**/*.js\"",
    "format:check": "prettier --check \"*.{js,css,html,json}\" \"js/**/*.js\" \"server/**/*.js\"",
    "lint": "eslint js app.js sw.js server",
    "icons": "node icons/generate-icons.mjs",
    "serve": "python3 -m http.server 8080"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "prettier": "^3.3.3"
  }
}
